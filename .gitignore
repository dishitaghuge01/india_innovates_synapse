# ================================
# Environment variables
# ================================

.env
.env.*

# ================================
# Python virtual environments
# ================================

venv/
env/
.venv/

# ================================
# Python cache
# ================================

__pycache__/
*.pyc
*.pyo
*.pyd

# ================================
# Logs
# ================================

logs/
*.log

# ================================
# OS files
# ================================

.DS_Store
Thumbs.db

# ================================
# IDE
# ================================

.vscode/
.idea/

# ================================
# Data generated by ingestion pipeline
# ================================

data/raw/*
data/processed/*
data/temp/*
data/vector_store/*
data/cache/*

# Allow folder structure but ignore files
!data/raw/.gitkeep
!data/processed/.gitkeep
!data/temp/.gitkeep
!data/vector_store/.gitkeep
!data/cache/.gitkeep

# ================================
# Graph databases / embeddings
# ================================

graph/*

# Ignore FAISS index files (but NOT python code)
*.index
*.faiss
*.npy

# ================================
# Model artifacts
# ================================

models/*.bin
models/*.pt
models/*.pkl

# ================================
# Build files
# ================================

dist/
build/
*.egg-info/

# ================================
# Temporary files
# ================================

*.tmp
*.bak
*~
